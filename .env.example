# Nyx Terminal — Environment Variables
# Copy this file to .env and fill in your keys

# Anthropic (Claude AI) — required for the AI agent
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Apify — required for live web/Twitter/Reddit scraping
APIFY_TOKEN=apify_api_your-token-here

# PostgreSQL — optional, enables persistent context & full-text search
DATABASE_URL=postgresql://nyx:nyx@localhost:5432/nyx

# Diaricat Live transcription service (default: local)
DIARICAT_LIVE_URL=http://127.0.0.1:8766
