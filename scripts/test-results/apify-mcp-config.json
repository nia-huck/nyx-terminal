{
  "___NOTA___": "Copiar la versión que necesites a claude_desktop_config.json",

  "VERSION_BASICA": {
    "mcpServers": {
      "apify": {
        "command": "npx",
        "args": ["-y", "@apify/mcp-server-apify"],
        "env": {
          "APIFY_TOKEN": "apify_api_YOUR_TOKEN_HERE"
        }
      }
    }
  },

  "VERSION_NYX_TERMINAL": {
    "mcpServers": {
      "apify": {
        "command": "npx",
        "args": [
          "-y", "@apify/mcp-server-apify",
          "--actors", "apify/rag-web-browser,apidojo/tweet-scraper,easyapi/google-news-scraper"
        ],
        "env": {
          "APIFY_TOKEN": "apify_api_YOUR_TOKEN_HERE"
        }
      }
    }
  }
}
